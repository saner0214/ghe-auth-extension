{
  "name": "copilot-provider-helper",
  "displayName": "Copilot Provider Helper",
  "description": "Enterprise authentication provider configuration helper for VS Code",
  "version": "1.3.0",
  "publisher": "saner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saner0214/ghe-auth-extension"
  },
  "homepage": "https://github.com/saner0214/ghe-auth-extension#readme",
  "bugs": {
    "url": "https://github.com/saner0214/ghe-auth-extension/issues"
  },
  "engines": {
    "vscode": "^1.73.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "enterprise",
    "authentication",
    "provider"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Copilot Provider Helper",
      "properties": {
        "github-enterprise.uri": {
          "type": "string",
          "default": "",
          "description": "GitHub Enterprise Server URL"
        },
        "github.copilot.advanced": {
          "type": "object",
          "default": {},
          "description": "Advanced configuration for GitHub Copilot",
          "properties": {
            "authProvider": {
              "type": "string",
              "enum": [
                "",
                "github-enterprise"
              ],
              "description": "Authentication provider for GitHub Copilot"
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "gheAuth.setup",
        "title": "Copilot Provider: Setup"
      },
      {
        "command": "gheAuth.signIn",
        "title": "Copilot Provider: Sign In"
      },
      {
        "command": "gheAuth.checkSession",
        "title": "Copilot Provider: Check Status"
      },
      {
        "command": "gheAuth.openSettings",
        "title": "Copilot Provider: Open Settings"
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}